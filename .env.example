# 119 Helper API Keys
# 이 파일을 .env로 복사한 후 실제 API 키를 입력하세요
# ──────────────────────────────────

# 기상청 API Hub (apihub.kma.go.kr)
VITE_KMA_API_KEY=your_kma_api_key_here

# 응급의료기관 정보 조회 서비스 (data.go.kr)
VITE_ER_API_KEY=your_er_api_key_here

# 한국천문연구원 특일 정보 (data.go.kr)
VITE_HOLIDAY_API_KEY=your_holiday_api_key_here

# 카카오맵 JavaScript API (developers.kakao.com)
VITE_KAKAO_MAP_KEY=your_kakao_map_key_here

# 건축물대장 API (data.go.kr)
VITE_BUILDING_API_KEY=your_building_api_key_here

# 소방용수시설 API (data.go.kr)
VITE_FIRE_WATER_API_KEY=your_fire_water_api_key_here

# 에어코리아 대기질 API (data.go.kr)
VITE_AIR_API_KEY=your_air_api_key_here

# ──────────────────────────────────
# 아래는 추후 API 신청 후 추가 예정
# ──────────────────────────────────

# 위험물제조소 API (data.go.kr) — 미신청
# VITE_HAZMAT_API_KEY=your_hazmat_api_key_here

